# Copy to .env for local runs. NEVER commit a real .env.
# All values are also injected via the Kubernetes ConfigMap (see k8s/configmap.yaml).

# --- LLM backend (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:0.5b
LLM_NUM_CTX=2048
LLM_TEMPERATURE=0.0
LLM_SEED=0
LLM_TIMEOUT_S=30.0

# --- Embeddings ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Retrieval ---
TOP_K=3
KB_PATH=data/kb.json
INDEX_PATH=data/index.npz

# --- Agentic router thresholds (calibrated by grid-search — see eval/results.md) ---
# Answer when top-1 cosine >= T_HIGH AND (top1 - top2) margin >= T_MARGIN.
# Clarify when in-domain but weak/near-tie. Decline when top-1 < T_LOW.
T_HIGH=0.59
T_LOW=0.56
T_MARGIN=0.02

# Use the LLM as a grounding/scope guard on the answer path (deterministic at temperature 0).
# Off by default for a fully deterministic demo; the deterministic router already routes.
LLM_GROUNDING_GUARD=true

# --- Service ---
LOG_LEVEL=INFO
