# Copy to .env for local runs. NEVER commit a real .env.
# All values are also injected via the Kubernetes ConfigMap (see k8s/config.env).

# --- LLM backend (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:0.5b
LLM_NUM_CTX=2048
LLM_TEMPERATURE=0.0
LLM_SEED=0
# Generous for a cold model load on CPU under memory pressure (see config.py).
LLM_TIMEOUT_S=120.0

# --- Embeddings ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Retrieval ---
TOP_K=3
KB_PATH=data/kb.json
INDEX_PATH=data/index.npz

# --- Agentic router thresholds (calibrated by grid-search — see eval/results.md) ---
# Answer when top-1 cosine >= T_HIGH AND (top1 - top2) margin >= T_MARGIN.
# Clarify when in-domain but weak/near-tie. Decline when top-1 < T_LOW.
T_HIGH=0.59
T_LOW=0.56
T_MARGIN=0.02

# Best-effort LLM grounding/scope guard on the answer path (deterministic at temperature 0).
# ON by default; it only ever downgrades answer -> decline. Set false for a router-only demo.
# Note: at 0.5B this guard is unreliable (catches some code phrasings, misses others) — the
# primary out-of-scope defense is the deterministic router (Q10 exemplar + T_LOW floor).
LLM_GROUNDING_GUARD=true

# --- Service ---
LOG_LEVEL=INFO
# Support contact used in fallback messages (mirrors the KB; override per environment).
SUPPORT_EMAIL=support@test.com
