# Non-secret runtime config. Consumed by kustomize's configMapGenerator, which
# appends a content hash to the ConfigMap name so changing any value here triggers
# a rolling restart of the agent automatically. No secrets belong in this file.
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:0.5b
LLM_NUM_CTX=2048
LLM_TEMPERATURE=0.0
LLM_SEED=0
LLM_TIMEOUT_S=30.0
LLM_GROUNDING_GUARD=true
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_CACHE_DIR=/opt/fastembed
TOP_K=3
KB_PATH=data/kb.json
INDEX_PATH=data/index.npz
T_HIGH=0.59
T_LOW=0.56
T_MARGIN=0.02
LOG_LEVEL=INFO
